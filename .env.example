# Genflow Ad Studio — example environment.
# Copy to `.env` for local dev, OR (preferred) source from Doppler with:
#   doppler setup --project genflow --config dev
#   doppler run -- make dev
# `.env` is gitignored; never commit real secrets here.

# ─── Google Cloud ────────────────────────────────
PROJECT_ID=your-gcp-project-id
REGION=us-central1
GOOGLE_CLOUD_LOCATION=us-central1
GCS_BUCKET_NAME=genflow-ad-studio-veo-output
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Path to a GCP service-account JSON. For local dev only — in Doppler/prod,
# prefer GOOGLE_APPLICATION_CREDENTIALS_JSON (raw JSON) and let an entrypoint
# materialize it to a tmpfs file at boot, or use Workload Identity / ADC.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ─── Model IDs ──────────────────────────────────
VEO_MODEL_ID=veo-3.1-generate-preview
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-3-flash-preview
IMAGE_MODEL=gemini-3-pro-image-preview

# ─── Pipeline ───────────────────────────────────
OUTPUT_DIR=output
STORYBOARD_QC_THRESHOLD=60
VIDEO_QC_THRESHOLD=6

# ─── Observability (Langfuse) ───────────────────
# When set, every agent run, model call, and pipeline step is captured as a
# trace in Langfuse. When unset, the SDK is silent — local dev unaffected.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# LANGFUSE_RELEASE=  # optional, e.g. git short-sha for grouped analytics
